{
  "name": "jarvis-installer-unofficial",
  "version": "0.1.0",
  "private": true,
  "description": "Unofficial cross-platform installer and control panel for Jarvis",
  "main": "dist-electron/main.js",
  "homepage": "https://github.com/Yperbu9474/jarvis-installer-unofficial",
  "author": {
    "name": "Codex",
    "email": "codex@example.com"
  },
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"tsup electron/main.ts electron/preload.ts --format cjs --out-dir dist-electron --watch\" \"wait-on tcp:5173 file:dist-electron/main.js && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build:web": "vite build",
    "build:electron": "tsup electron/main.ts electron/preload.ts --format cjs --out-dir dist-electron",
    "build": "npm run build:web && npm run build:electron",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win nsis",
    "dist:mac": "npm run build && electron-builder --mac dmg",
    "dist:linux": "npm run build && electron-builder --linux AppImage deb",
    "typecheck": "tsc --noEmit"
  },
  "build": {
    "appId": "dev.usejarvis.installer.unofficial",
    "productName": "Jarvis Installer",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "package.json"
    ],
    "asar": true,
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg"
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development",
      "maintainer": "Codex <codex@example.com>"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "electron-log": "^5.2.4",
    "node-pty": "^1.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.2",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.5",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^35.1.4",
    "electron-builder": "^25.1.8",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.2",
    "wait-on": "^8.0.3"
  },
  "optionalDependencies": {
    "dmg-license": "^1.0.11"
  }
}
